{
  "manifest_version": 3,
  "name": "AI Nag Browser",
  "version": "1.0",
  "description": "AI roasts your Google searches using a local Ollama model.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:11434/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*"
      ],
      "js": [
        "log.js",
        "ai.js",
        "ui.js",
        "content.js"
      ],
      "css": [
        "css/style.css"
      ]
    }
  ]
}